#! /bin/bash

_py_completion() {
    local cur prev cmd raw_cmd
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    raw_cmd="${COMP_WORDS[1]}"
    cmd="$raw_cmd"

    case "$raw_cmd" in
        I|init)                cmd="init" ;;
        R|reinit)              cmd="reinit" ;;
        registry)              cmd="registry" ;;
        a|add)                 cmd="add" ;;
        rm|remove|d|del|delete) cmd="remove" ;;
        i|ins|install)         cmd="install" ;;
        u|uns|uninstall)       cmd="uninstall" ;;
        U|up|update)           cmd="update" ;;
        x|exec|run)            cmd="exec" ;;
        .)                     cmd="dot" ;;
        ls|list)               cmd="list" ;;
        b|build)               cmd="build" ;;
        p|publish|push)        cmd="push" ;;
        sh|shell|activate)     cmd="shell" ;;
        v|version)             cmd="version" ;;
        help|-h|--help)        cmd="help" ;;
        *)                     ;;
    esac

    if [[ $COMP_CWORD -eq 1 ]]; then
        local commands="init reinit registry . add list version build push install uninstall remove shell exec update"
        COMPREPLY=($(compgen -W "${commands}" -- "$cur"))
        return 0
    fi

    case "$cmd" in
        help)
            return 0
            ;;
        init|reinit)
            if [[ $COMP_CWORD -eq 2 ]]; then
                local envs
                envs=$(ls requirements* 2>/dev/null | sed 's/requirements\.//g; s/\.txt//g')
                COMPREPLY=($(compgen -W "$envs" -- "$cur"))
            fi
            return 0
            ;;
        registry)
            if [[ $COMP_CWORD -eq 2 ]]; then
                local registry_cmds="list new remove"
                COMPREPLY=($(compgen -W "$registry_cmds" -- "$cur"))
            fi
            return 0
            ;;
        add)
            if [[ $cur == -* ]]; then
                local opts="--from --name --version --branch --commit --protocol --no-deps --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
            else
                COMPREPLY=($(compgen -f -- "$cur"))
            fi
            return 0
            ;;
        remove)
            if [[ $COMP_CWORD -eq 2 ]]; then
                local names
                names="$(_py_dep_names)"
                COMPREPLY=($(compgen -W "${names}" -- "${cur}"))
            else
                COMPREPLY=($(compgen -W "$(_py_dep_names)" -- "$cur"))
            fi
            return 0
            ;;
        install)
            if [[ $cur == -* ]]; then
                local opts="--from --registry --to --env --path --recursive --no-deps --branch --commit --version --protocol --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
            else
                COMPREPLY=($(compgen -f -- "$cur"))
            fi
            return 0
            ;;
        uninstall)
            if [[ $cur == -* ]]; then
                local opts="--from --registry --to --env --path --recursive --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
                return 0
            fi

            local names
            names="$(_py_uninstall_candidates)"
            COMPREPLY=($(compgen -W "${names}" -- "${cur}"))
            return 0
            ;;
        update)
            if [[ $cur == -* ]]; then
                local opts="--env --from --recursive --path --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
                return 0
            fi

            local names
            names="$(_py_dep_names)"
            COMPREPLY=($(compgen -W "${names}" -- "${cur}"))
            return 0
            ;;
        exec)
            if [[ $cur == -* ]]; then
                local opts="--from --env --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
            else
                COMPREPLY=($(compgen -f -- "$cur"))
            fi
            return 0
            ;;
        dot)
            if [[ $COMP_CWORD -eq 2 ]]; then
                local names
                names="$(_py_installed_packages)"
                COMPREPLY=($(compgen -W "${names}" -- "${cur}"))
            elif [[ $cur == -* ]]; then
                COMPREPLY=($(compgen -W "--env -e" -- "$cur"))
            fi
            return 0
            ;;
        list)
            if [[ $cur == -* ]]; then
                local opts="--installed --not-installed --env -e --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
            fi
            return 0
            ;;
        build)
            if [[ $cur == -* ]]; then
                local opts="--env -e --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
            fi
            return 0
            ;;
        push)
            if [[ $cur == -* ]]; then
                local opts="--registry -r --env -e --user -u --pass -p --url --help"
                COMPREPLY=($(compgen -W "$opts" -- "$cur"))
            fi
            return 0
            ;;
        shell)
            if [[ $COMP_CWORD -eq 2 ]]; then
                local envs
                envs=$(ls requirements* 2>/dev/null | sed 's/requirements\.//g; s/\.txt//g')
                COMPREPLY=($(compgen -W "$envs" -- "$cur"))
            fi
            return 0
            ;;
        version)
            if [[ $COMP_CWORD -eq 2 ]]; then
                if [[ "$cur" == -* ]]; then
                    COMPREPLY=($(compgen -W "--from --help" -- "$cur"))
                else
                    COMPREPLY=($(compgen -W "up down" -- "$cur"))
                fi
                return 0
            fi

            if [[ $COMP_CWORD -eq 3 ]]; then
                case "$prev" in
                    up|down)
                        COMPREPLY=($(compgen -W "patch minor major" -- "$cur"))
                        return 0
                        ;;
                    --from)
                        COMPREPLY=($(compgen -W "git" -- "$cur"))
                        return 0
                        ;;
                esac
            fi

            return 0
            ;;
        *)
            return 0
            ;;
    esac
}

_py_find_pyproject() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/pyproject.toml" ]]; then
            echo "$dir/pyproject.toml"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

_py_dep_names() {
    local pyproject
    pyproject="$(_py_find_pyproject)" || return 0

    awk '
    BEGIN { in_deps = 0 }
    /^[[:space:]]*dependencies[[:space:]]*=[[:space:]]*\[/ {
        in_deps = 1
        # If line contains closing bracket, we are done
        if (index($0, "]")) exit
        next
    }
    in_deps && /\]/ { exit }
    in_deps && /^[[:space:]]*".*"[[:space:]]*(,)?$/ {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "")
        gsub(/^"|"$/, "")
        gsub(/,$/, "")
        gsub(/[<>=! @].*$/, "")
        if (length($0) > 0) print $0
    }
    ' "$pyproject"
}

_py_installed_packages() {
    local pyproject
    pyproject="$(_py_find_pyproject)" || return 0

    local root site_dir
    root="$(dirname "$pyproject")"
    site_dir="$root/.venv/site-packages"

    [[ -d "$site_dir" ]] || return 0

    ls -1 "$site_dir" 2>/dev/null \
        | grep -E '^[a-zA-Z0-9_]' \
        | grep -v -E '\.dist-info$|\.egg-info$|^__pycache__$'
}

_py_uninstall_candidates() {
    local deps
    deps="$(_py_dep_names)"

    local pyproject
    pyproject="$(_py_find_pyproject)" || {
        printf '%s\n' "$deps"
        return 0
    }

    local root site_dir inst=""
    root="$(dirname "$pyproject")"
    site_dir="$root/.venv/site-packages"

    if [[ -d "$site_dir" ]]; then
        inst=$(find "$site_dir" -maxdepth 1 -type d -name "*.dist-info" 2>/dev/null \
            | xargs -r -n 1 basename \
            | sed 's/-[^-]*\.dist-info$//' \
            | sed 's/\.dist-info$//' \
            | sort -u)
    fi

    printf '%s\n%s\n' "$deps" "$inst" | awk 'NF && !seen[$0]++'
}

complete -F _py_completion py

